{
  "manifest_version": 3,
  "name": "Cafe Bot - Enhanced Fake Camera",
  "version": "8.0.21",
  "description": "Versao Otimizada Definitiva com Injecao Continua Persistente",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.vfsglobal.com/*",
    "https://vfsglobal.com/*",
    "https://*.vfsvisaonline.com/*",
    "https://vfsvisaonline.com/*"
  ],
  "content_scripts": [
  "scripts/upload_galeria.js"
    {
      "matches": [
        "https://*.vfsglobal.com/*",
        "https://vfsglobal.com/*",
        "https://*.vfsvisaonline.com/*",
        "https://vfsvisaonline.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "Cafe Bot - Fake Camera"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
